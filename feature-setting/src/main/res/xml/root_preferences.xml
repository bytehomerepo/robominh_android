<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory app:title="@string/messages_header">
        <ListPreference
            app:defaultValue="reply"
            app:entries="@array/option_voice"
            app:entryValues="@array/option_voice"
            app:key="option_voice"
            app:title="@string/title_voice"
            app:useSimpleSummaryProvider="true" />
        <ListPreference
            app:defaultValue="chế độ liên tục"
            app:entries="@array/option_mode"
            app:entryValues="@array/option_mode"
            app:key="option_mode"
            app:title="@string/title_mode"
            app:useSimpleSummaryProvider="true" />
        <SwitchPreferenceCompat
            app:key="dark_mode"
            app:title="@string/title_dark_mode" />
    </PreferenceCategory>
</PreferenceScreen>